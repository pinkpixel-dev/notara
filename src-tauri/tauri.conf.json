{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Notara",
  "version": "1.1.0",
  "identifier": "dev.pinkpixel.notara",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3489",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Notara",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Local-first note-taking app with markdown editing and AI tools.",
    "longDescription": "Notara is a local-first desktop notes workspace with markdown editing, todo management, vision boards, and optional AI assistance.",
    "copyright": "Copyright (c) Pink Pixel",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {}
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
